{erl_opts, [debug_info]}.
{deps, [{jsx, "3.1.0"}]}.

{relx, [{release, {erlang_app, "0.1.0"},
         [erlang_app,
          sasl,
          jsx]},

        {mode, prod},

        %% extend start_erl.data with app version and erts version
        %% (this is what the loader expects)
        {include_erts, false},
        {extended_start_script, true}]
}.

{profiles, [{prod, [{relx, [{dev_mode, false},
                            {include_src, false}]}]}
           ]}.
