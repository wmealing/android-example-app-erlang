{erl_opts, [debug_info]}.

{deps, [
    {jsx, "3.1.0"},
    {wade, "0.2.2"}
]}.

{relx, [
    {release, {erlang_app, "0.1.0"}, [
        erlang_app,
        sasl,
	inets, 
        jsx,
        wade
    ]},

    {mode, prod},

    %% extend start_erl.data with app version and erts version
    {include_erts, false},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_src, false}
        ]}
    ]}
]}.
